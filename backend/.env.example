# ── Supabase PostgreSQL connection (psycopg2 direct — no Supabase SDK needed) ──
DATABASE_HOST=aws-0-eu-west-1.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.your-project-ref
DATABASE_PASSWORD=your-database-password

# ── Self-managed JWT ─────────────────────────────────────────────────────────
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440   # 24 hours

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Google Gemini API (legacy — kept for reference) ──────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── OpenRouter API (used for natural language query feature) ─────────────────
# Sign up at https://openrouter.ai — free tier available
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Paystack payment gateway ─────────────────────────────────────────────────
# Get keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
# URL where Paystack redirects after payment (your frontend /payment/callback)
PAYSTACK_CALLBACK_URL=https://your-app.vercel.app/payment/callback

# ── CORS — comma-separated list of allowed frontend URLs ─────────────────────
CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
