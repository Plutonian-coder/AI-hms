# ── Supabase PostgreSQL connection (psycopg2 direct — no Supabase SDK needed) ──
DATABASE_HOST=aws-0-eu-west-1.pooler.supabase.com
DATABASE_PORT=6543
DATABASE_NAME=postgres
DATABASE_USER=postgres.your-project-ref
DATABASE_PASSWORD=your-database-password

# ── Self-managed JWT ─────────────────────────────────────────────────────────
# Generate a strong secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-super-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440   # 24 hours

# ── File Uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Gemini API (for receipt OCR) ─────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── CORS — comma-separated list of allowed frontend URLs ─────────────────────
CORS_ORIGINS=http://localhost:5173

# NOTE: SUPABASE_URL and SUPABASE_ANON_KEY are no longer needed.
# Auth is now self-managed via bcrypt + JWT (python-jose + passlib).
# The Supabase Postgres DATABASE_* vars above are the only Supabase dependency.
